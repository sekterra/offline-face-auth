<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.faceauth.sdk" >

    <uses-sdk android:minSdkVersion="35" />

    <!-- 카메라 권한 -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- 진동(챌린지 피드백) -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <uses-feature
        android:name="android.hardware.camera.front"
        android:required="true" />

    <application>

        <!-- 내장 등록 Activity -->
        <activity
            android:name="com.faceauth.sdk.camera.EnrollmentActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.FaceAuth" />

        <!-- 내장 인증 Activity -->
        <activity
            android:name="com.faceauth.sdk.camera.AuthenticationActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.FaceAuth" />
    </application>

</manifest>